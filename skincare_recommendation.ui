}

QPushButton#btn_recommend {
    background-color: #D97757;
    color: #FFFFFF;
    border: none;
    border-radius: 18px;
    font-size: 16px;
    font-weight: 900;
}

QPushButton#btn_recommend:hover {
    background-color: #C9684C;
}

QPushButton#btn_recommend:pressed {
