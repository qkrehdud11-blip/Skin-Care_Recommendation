}

QTextBrowser#lb_recommendation {
    background-color: #FFFFFF;
    border: 1px solid #DDEBD7;
    border-radius: 22px;
    padding: 26px;
    color: #333333;
    font-size: 15px;
}

QTextBrowser {
    selection-background-color: #D97757;
}

QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 8px 2px 8px 2px;
}

QScrollBar::handle:vertical {
    background: #D8BFAF;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #C9A996;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    height: 0px;
}
